rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isValidMessage(data) {
      return data.role is string && (data.role == "user" || data.role == "bot") &&
             data.text is string && data.text.size() <= 2000 &&
             data.createdAt is timestamp;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /chat_history/{messageId} {
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(request.resource.data) && request.resource.data.userEmail == request.auth.token.email;
    }
  }
}
